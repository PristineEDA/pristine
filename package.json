{
  "name": "pristine",
  "productName": "Pristine",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "prepare:assets": "node scripts/prepare-assets.mjs",
    "prepare:slang-server": "node scripts/prepare-slang-server.mjs",
    "generate:mastra-model-catalog": "node scripts/generate-mastra-model-catalog.mjs",
    "sync:mastra-provider-logos": "node scripts/sync-mastra-provider-logos.mjs",
    "verify:node-pty-binary": "node scripts/verify-node-pty-binary.mjs",
    "build:app": "pnpm run prepare:assets && pnpm run prepare:slang-server && vite build",
    "predev": "pnpm run prepare:assets && pnpm run prepare:slang-server",
    "dev": "vite",
    "dev:web": "vite --config vite.config.web.ts",
    "agent:dev": "pnpm --filter @pristine/agent-server dev",
    "agent:build": "pnpm --filter @pristine/agent-server build",
    "agent:typecheck": "pnpm --filter @pristine/agent-server typecheck",
    "agent:test": "pnpm --filter @pristine/agent-server test",
    "build": "pnpm run build:app",
    "preview": "pnpm run build:app && electron .",
    "package": "pnpm run build:app && electron-builder --config electron-builder.yml",
    "package:win": "pnpm run build:app && pnpm run verify:node-pty-binary -- --platform win32 --arch x64 && electron-builder --win --config electron-builder.win.yml",
    "package:linux": "pnpm run build:app && electron-builder --linux --config electron-builder.yml",
    "package:mac": "pnpm run build:app && electron-builder --mac --config electron-builder.yml",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --max-failures=1",
    "test:whiteboard:perf": "playwright test --config playwright.perf.config.ts e2e/whiteboard.perf.spec.ts",
    "package:linux:x64": "pnpm run build:app && electron-builder --linux AppImage deb --x64 --config electron-builder.yml",
    "package:win:x64": "pnpm run build:app && pnpm run verify:node-pty-binary -- --platform win32 --arch x64 && electron-builder --win nsis portable --x64 --config electron-builder.win.yml",
    "package:mac:x64": "pnpm run build:app && electron-builder --mac dmg --x64 --config electron-builder.yml",
    "package:mac:arm64": "pnpm run build:app && electron-builder --mac dmg --arm64 --config electron-builder.yml"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.171",
    "@assistant-ui/react": "^0.12.27",
    "@assistant-ui/react-ai-sdk": "^1.3.21",
    "@assistant-ui/react-markdown": "^0.12.11",
    "@assistant-ui/react-streamdown": "^0.1.11",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.169",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "ignore": "^7.0.5",
    "lucide-react": "0.487.0",
    "material-icon-theme": "^5.33.1",
    "mermaid": "^11.14.0",
    "monaco-editor": "0.55.1",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-shiki": "^0.9.3",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-shimmer": "^0.4.11",
    "vscode-jsonrpc": "^8.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@fontsource/anonymous-pro": "^5.2.8",
    "@fontsource/cascadia-code": "^5.2.3",
    "@fontsource/comic-mono": "^5.2.5",
    "@fontsource/cousine": "^5.2.7",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inconsolata": "^5.2.8",
    "@fontsource/iosevka": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/mononoki": "^5.2.5",
    "@fontsource/noto-sans-mono": "^5.2.10",
    "@fontsource/source-code-pro": "^5.2.7",
    "@fontsource/space-mono": "^5.2.9",
    "@fontsource/ubuntu-mono": "^5.2.8",
    "@fontsource/victor-mono": "^5.2.8",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "extract-zip": "^2.0.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "4.2.2",
    "tar-fs": "^3.1.2",
    "typescript": "^5.6.0",
    "unbzip2-stream": "^1.4.3",
    "vite": "8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}